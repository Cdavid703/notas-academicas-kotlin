<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_app"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTitulo"
            style="@style/EstiloTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/titulo_app"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <TextView
            style="@style/EstiloEtiqueta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_nombre_estudiante" />

        <EditText
            android:id="@+id/etNombreEstudiante"
            style="@style/EstiloEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_nombre_estudiante"
            android:inputType="textPersonName"
            android:layout_marginBottom="16dp" />

        <TextView
            style="@style/EstiloEtiqueta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_materia" />

        <EditText
            android:id="@+id/etMateria"
            style="@style/EstiloEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_materia"
            android:inputType="textCapWords"
            android:layout_marginBottom="16dp" />

        <TextView
            style="@style/EstiloEtiqueta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_conocimiento" />

        <EditText
            android:id="@+id/etConocimiento"
            style="@style/EstiloEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_nota"
            android:inputType="numberDecimal"
            android:layout_marginBottom="16dp" />

        <TextView
            style="@style/EstiloEtiqueta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_desempeno" />

        <EditText
            android:id="@+id/etDesempeno"
            style="@style/EstiloEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_nota"
            android:inputType="numberDecimal"
            android:layout_marginBottom="16dp" />

        <TextView
            style="@style/EstiloEtiqueta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_producto" />

        <EditText
            android:id="@+id/etProducto"
            style="@style/EstiloEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_nota"
            android:inputType="numberDecimal"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnCalcular"
            style="@style/EstiloBoton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/boton_calcular"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvResultado"
            style="@style/EstiloResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/resultado_inicial" />

    </LinearLayout>
</ScrollView>